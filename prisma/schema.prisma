// Immo Score — Schéma Prisma
// Schéma PostgreSQL isolé : immo_score (via ?schema=immo_score dans DATABASE_URL)
// Toutes les tables sont créées dans le schéma immo_score, séparé de Homilink.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum EquipementCategorie {
  HEALTH
  EDUCATION
  RETAIL
  GREEN
}

enum NiveauRisque {
  FAIBLE
  MOYEN
  FORT
  TRES_FORT
}

enum Profile {
  ACHETEUR
  INVESTISSEUR
  FAMILLE
  RETRAITE
}

// ─────────────────────────────────────────────
// Table 1 : communes
// Référentiel COG INSEE (~35 000 communes)
// ─────────────────────────────────────────────

model Commune {
  code_insee  String @id
  nom         String
  departement String
  region      String
  population  Int?
  superficie  Float?
  slug        String @unique
  lat         Float?
  lng         Float?

  // v4 — Accessibilité financière
  aav_code         String? // Code AAV 2020 (Aires d'Attraction des Villes, INSEE)
  prix_tx_median3y Float? // Prix médian transaction sur 3 ans glissants (€) — calculé depuis DVF

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  dvf_prix          DvfPrix[]
  dpe               DpeCommune[]
  equipements       Equipement[]
  bpe               BpeCommune?
  risques           Risque[]
  fiscalite         Fiscalite[]
  demographie       Demographie[]
  score             Score?
  filosofi_v2       FilosofiCommune?
  score_commune     ScoreCommune?
  score_profiles    ScoreProfile[]
  fiscalite_commune    FiscaliteCommune?
  loyer_commune        LoyerCommune?
  taxe_fonciere        TaxeFonciereCommune?

  @@map("communes")
}

// ─────────────────────────────────────────────
// Table 2 : dvf_prix
// Transactions Demande de Valeurs Foncières (DVF)
// ─────────────────────────────────────────────

model DvfPrix {
  id                  String   @id @default(cuid())
  code_commune        String
  date_mutation       DateTime
  type_local          String
  surface_reelle_bati Float?
  valeur_fonciere     Float
  prix_m2             Float?
  adresse             String?

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@index([code_commune])
  @@index([date_mutation])
  @@map("dvf_prix")
}

// ─────────────────────────────────────────────
// Table 3 : dpe_communes
// Diagnostics de Performance Énergétique (ADEME), agrégés par commune
// ─────────────────────────────────────────────

model DpeCommune {
  id                        String @id @default(cuid())
  code_commune              String
  classe_dpe                String // A, B, C, D, E, F, G
  nb_logements              Int
  annee_construction_median Int?
  conso_energie_median      Float?

  date_ingestion DateTime @default(now())
  updated_at     DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@index([code_commune])
  @@map("dpe_communes")
}

// ─────────────────────────────────────────────
// Table 4a : bpe_communes
// Base Permanente des Équipements (BPE INSEE) 2023 — agrégé par commune
// 30 équipements essentiels, score 0-30 brut → normalize 0-100
// ─────────────────────────────────────────────

model BpeCommune {
  id           String @id @default(cuid())
  code_commune String @unique

  // Comptages par sous-catégorie (nombre d'équipements distincts présents)
  education_count     Int @default(0)
  sante_count         Int @default(0)
  commerces_count     Int @default(0)
  transport_count     Int @default(0)
  culture_sport_count Int @default(0)

  // 30 flags booléens — présence d'au moins 1 établissement de ce type
  has_creche           Boolean @default(false) // C501
  has_ecole_maternelle Boolean @default(false) // C101
  has_ecole_primaire   Boolean @default(false) // C102
  has_college          Boolean @default(false) // C201
  has_lycee            Boolean @default(false) // C301
  has_medecin          Boolean @default(false) // D201
  has_dentiste         Boolean @default(false) // D231
  has_pharmacie        Boolean @default(false) // D301
  has_urgences         Boolean @default(false) // D401
  has_maternite        Boolean @default(false) // D402
  has_hopital          Boolean @default(false) // D501
  has_ehpad            Boolean @default(false) // D106
  has_hypermarche      Boolean @default(false) // B101
  has_superette        Boolean @default(false) // B102
  has_boulangerie      Boolean @default(false) // B201
  has_librairie        Boolean @default(false) // B203
  has_banque           Boolean @default(false) // B301
  has_poste            Boolean @default(false) // B306
  has_police           Boolean @default(false) // A101
  has_gare_national    Boolean @default(false) // E101
  has_gare_regional    Boolean @default(false) // E102
  has_arret_transport  Boolean @default(false) // E103
  has_autoroute        Boolean @default(false) // E107
  has_aeroport         Boolean @default(false) // E201
  has_cinema           Boolean @default(false) // F101
  has_salle_spectacle  Boolean @default(false) // F111
  has_piscine          Boolean @default(false) // F201
  has_stade            Boolean @default(false) // F301
  has_gymnase          Boolean @default(false) // F302
  has_tennis           Boolean @default(false) // F303

  // Score brut : nombre de flags à true (0-30)
  total_equip_essentiels Int @default(0)

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@map("bpe_communes")
}

// ─────────────────────────────────────────────
// Table 4b : equipements (ancien modèle normalisé — conservé pour rétrocompatibilité)
// ─────────────────────────────────────────────

model Equipement {
  id                 String              @id @default(cuid())
  code_commune       String
  categorie          EquipementCategorie
  type_equipement    String
  nb_etablissements  Int
  distance_centre_km Float?

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@index([code_commune])
  @@index([categorie])
  @@map("equipements")
}

// ─────────────────────────────────────────────
// Table 5 : risques
// Géorisques — risques naturels et technologiques par commune
// ─────────────────────────────────────────────

model Risque {
  id           String       @id @default(cuid())
  code_commune String
  type_risque  String
  niveau       NiveauRisque
  description  String?

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@index([code_commune])
  @@map("risques")
}

// ─────────────────────────────────────────────
// Table 6 : fiscalite
// Taxe foncière par commune (data.economie.gouv.fr)
// ─────────────────────────────────────────────

model Fiscalite {
  id                   String @id @default(cuid())
  code_commune         String
  annee                Int
  taux_taxe_fonciere   Float?
  taux_taxe_habitation Float?
  evolution_yoy        Float?

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@unique([code_commune, annee])
  @@index([code_commune])
  @@map("fiscalite")
}

// ─────────────────────────────────────────────
// Table 7 : demographie
// Démographie INSEE par commune
// ─────────────────────────────────────────────

model Demographie {
  id                 String @id @default(cuid())
  code_commune       String
  annee              Int
  population         Int
  evolution_5ans_pct Float?
  age_median         Float?
  taux_chomage       Float?
  revenu_median      Float?

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@unique([code_commune, annee])
  @@index([code_commune])
  @@map("demographie")
}

// ─────────────────────────────────────────────
// Table 9 : insee_filosofi
// Revenus médians par commune — Filosofi 2020 (INSEE)
// Source : https://www.insee.fr/fr/statistiques/6692392
// ─────────────────────────────────────────────

model InseeFilosofi {
  id            Int      @id @default(autoincrement())
  code_commune  String   @unique
  revenu_median Float // MED20 : revenu médian par UC en €/an (Filosofi 2020)
  annee         Int      @default(2020)
  created_at    DateTime @default(now())

  @@map("insee_filosofi")
}

// ─────────────────────────────────────────────
// Table 10 : filosofi_communes (v4)
// Revenus médians par UC + indicateurs complémentaires — Filosofi 2021
// Remplace insee_filosofi pour les calculs v4 (commune_id FK, champs étendus)
// ─────────────────────────────────────────────

model FilosofiCommune {
  id         String @id @default(cuid())
  commune_id String @unique

  median_uc     Float // MED_SL : revenu médian disponible par UC (€/an)
  taux_pauvrete Float? // TP60_SL : taux de pauvreté au seuil 60% (%)
  population    Int? // NBPERS : nb personnes dans les ménages fiscaux
  annee         Int    @default(2021)

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [commune_id], references: [code_insee], onDelete: Cascade)

  @@map("filosofi_communes")
}

// ─────────────────────────────────────────────
// Table 11 : cerema_accessibilite — Sprint 4-A patch
// Accessibilité financière par commune (Cerema DV3F 2022-2024).
// Source niveau 1 : données directes par commune (d5 = médiane = décile 5).
// commune_id = code INSEE 5 car. (clé unique, FK implicite).
// ─────────────────────────────────────────────

model CeremaAccessibilite {
  id         String  @id @default(cuid())
  commune_id String  @unique // Code INSEE commune 5 car.
  aav_code   String? // Code AAV 2020 INSEE (null = hors AAV)

  // Déciles en années de revenu UC (d3=D3, d5=médiane, d7=D7)
  d3_appart Float?
  d5_appart Float?
  d7_appart Float?
  d3_maison Float?
  d5_maison Float?
  d7_maison Float?

  annee      Int      @default(2024)
  source     String   @default("cerema-2022-2024")
  updated_at DateTime @updatedAt

  @@index([aav_code])
  @@map("cerema_accessibilite")
}

// ─────────────────────────────────────────────
// Table 12 : score_communes (v4)
// Scores d'accessibilité financière par commune (Sprint 4-A)
// Architecture v4 : table dédiée par dimension, FK sur code_insee
// ─────────────────────────────────────────────

model ScoreCommune {
  id         String @id @default(cuid())
  commune_id String @unique
  version    Int    @default(4)

  score_accessibilite_fin Float? // Score accessibilité financière (0-100, floor 10)
  median_multiple         Float? // Median Multiple calculé ou imputé
  accessibilite_imputed   Boolean @default(false)
  imputation_methods      Json? // { method, source, aav_code? }

  computed_at DateTime @default(now())
  updated_at  DateTime @updatedAt

  commune Commune @relation(fields: [commune_id], references: [code_insee], onDelete: Cascade)

  @@index([score_accessibilite_fin])
  @@map("score_communes")
}

// ─────────────────────────────────────────────
// Table 13 : score_profiles (v4)
// Scores globaux par profil acheteur (ACHETEUR, INVESTISSEUR, FAMILLE, RETRAITE)
// ─────────────────────────────────────────────

model ScoreProfile {
  id           String   @id @default(cuid())
  commune_id   String
  profile      Profile
  score_global Float
  updated_at   DateTime @updatedAt

  commune Commune @relation(fields: [commune_id], references: [code_insee], onDelete: Cascade)

  @@unique([commune_id, profile])
  @@index([commune_id])
  @@map("score_profiles")
}

// ─────────────────────────────────────────────
// Table 8 : scores
// Score composite calculé par commune (0–100)
// Recalculé après chaque ingestion via compute-scores.ts
// ─────────────────────────────────────────────

model Score {
  id                String   @id @default(cuid())
  code_commune      String   @unique
  score_global      Float
  score_dpe         Float?
  score_dvf         Float?
  score_bpe         Float?
  score_risques     Float?
  score_fiscalite   Float?
  score_demographie Float?
  computed_at       DateTime @default(now())
  version           Int      @default(1)

  // Imputation DVF (communes sans données : Alsace-Moselle, Mayotte)
  dvf_imputed        Boolean @default(false)
  dvf_imputed_method String?
  dvf_imputed_region String?
  dvf_imputed_value  Float?

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@index([score_global])
  @@map("scores")
}

// ─────────────────────────────────────────────
// Table 14 : fiscalite_communes (v4-TF)
// Taxe Foncière Bâtie par commune — OFGL REI 2023
// Source : data.ofgl.fr/explore/dataset/rei/
// Variables : E11 (base nette), E13 (produit réel), E14 (nb articles)
// ─────────────────────────────────────────────

model FiscaliteCommune {
  id         String @id @default(cuid())
  commune_id String @unique

  tf_base         Float? // E11 : base nette TFB commune (€)
  tf_produit      Float? // E13 : produit réel TFB commune (€)
  tf_nb_articles  Int? // E14 : nombre de locaux imposables
  tf_moy_par_bien Float? // E13/E14 : TF moyenne par logement (€/an)
  tf_taux_vote    Float? // E12VOTE : taux voté communal (%)
  annee           Int    @default(2023)

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [commune_id], references: [code_insee], onDelete: Cascade)

  @@map("fiscalite_communes")
}

// ─────────────────────────────────────────────
// Table 15 : loyer_communes (v4-LOY)
// Loyers médians par commune — Carte Loyers ANIL/Cerema 2023
// Source : pred-mai-mef-dhup.csv (data.gouv.fr)
// v4-LOY-3M (R2) : 6 colonnes source tracking ajoutées (DATA-v4-LOY-3M Phase 2 Step 1)
// ─────────────────────────────────────────────

model LoyerCommune {
  id         String @id @default(cuid())
  commune_id String @unique

  loyer_m2         Float? // loypredm2 : loyer médian prédit (€/m²)
  loyer_m2_ic_low  Float? // lwr.IPm2 : borne inférieure IC 95%
  loyer_m2_ic_high Float? // upr.IPm2 : borne supérieure IC 95%
  typpred          String? // "commune" | "maille" — indicateur de confiance
  nb_obs           Int? // nbobs_com : nb annonces au niveau commune
  r2_adj           Float? // qualité ajustement modèle (0–1)
  annee            Int     @default(2023)

  // v4-LOY-3M : hiérarchie de sources N1/N1bis/N2/N3/N4 (R2 — DATA-v4-LOY-3M)
  niveau    String // 'N1' | 'N1bis' | 'N2' | 'N3' | 'N4'
  source    String // 'carte_loyers_anil' | 'oll_paris' | 'oll_lyon' | 'oll_amp' | 'dvf_inverse' | 'regional_median' | 'national_median'
  millesime Int // millésime de la source (ex: 2023)
  nbObs     Int?     @map("nb_obs_src") // nb observations utilisées pour cette source (niveau commune ou maille)
  q1M2      Decimal? @db.Decimal(6, 2) @map("q1_m2") // 1er quartile loyer €/m²
  q3M2      Decimal? @db.Decimal(6, 2) @map("q3_m2") // 3e quartile loyer €/m²

  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [commune_id], references: [code_insee], onDelete: Cascade)

  @@index([niveau, source])
  @@map("loyer_communes")
}

// ─────────────────────────────────────────────
// Table 16 : taxe_fonciere_communes (v4-TF)
// Taxe Foncière Bâtie par commune — OFGL REI 2024
// Source : data.ofgl.fr — Licence Ouverte Etalab v2.0
// var codes : E11=base_nette, E13=montant_commune, E12VOTE=taux_commune
//             E31=base_nette_gfp, E33=montant_gfp, E32VOTE=taux_gfp
// Remplace FiscaliteCommune pour le pipeline v4 (millésime 2024, cumul commune+EPCI)
// ─────────────────────────────────────────────

model TaxeFonciereCommune {
  id           String @id @default(cuid())
  code_commune String @unique

  montant_tfb_communal Float?  // E13 : produit réel TFB commune (€/an)
  montant_tfb_epci     Float?  // E33 : produit réel TFB GFP/EPCI (€/an, null si EPCI sans TFB)
  montant_tfb_total    Float?  // E13 + E33 (€/an) — charge annuelle réelle propriétaire
  base_nette           Float?  // E11 : base nette TFB commune (€)
  taux_communal_pct    Float?  // E12VOTE : taux voté communal (%)
  taux_epci_pct        Float?  // E32VOTE : taux voté GFP/EPCI (%, null si EPCI sans TFB)
  millesime            Int     @default(2024)
  source               String  @default("ofgl-rei")
  secret_statistique   Boolean @default(false)
  sec_stat_reason      String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  commune Commune @relation(fields: [code_commune], references: [code_insee], onDelete: Cascade)

  @@index([taux_communal_pct])
  @@map("taxe_fonciere_communes")
}
